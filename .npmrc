# RP-DEASI-JUP-2026-0619-001 | Lockfile integrity enforcement
# Author: Richard Patterson (@De-ASI-INTERFACE)

# Enforce lockfile presence — npm install will write it, npm ci will validate it
package-lock=true

# Fail if engines field is violated (Node version contract enforcement)
engine-strict=true

# Disallow writing lockfile during ci installs (belt + suspenders alongside npm ci)
save=false

# Suppress audit noise in CI logs; run separately as a dedicated audit step
audit=false

# Workspace hoisting: hoist all common deps to root node_modules
hoist=true
